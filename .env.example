# Postgres connection (Railway provides DATABASE_URL automatically).
# If unset, the app uses an in-memory store (data resets on restart).
DATABASE_URL=

# Optional: enables live AI recommendations (Claude). Without it, the app
# returns curated Toronto suggestions near 57 Spadina Ave.
ANTHROPIC_API_KEY=

# REQUIRED for real security: a long random string used to sign login sessions.
# Generate one with:  openssl rand -hex 32
# If unset, an insecure dev default is used (fine for local, NOT for production).
AUTH_SECRET=

# Optional: a shared "family reset code". If someone forgets their PIN they can
# enter this code on the "Forgot PIN?" screen to set a new one. Leave blank to
# disable that path (members can still reset each other from the Account menu).
FAMILY_RESET_CODE=
